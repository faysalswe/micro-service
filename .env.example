# --- Global Settings ---
COMPOSE_PROJECT_NAME=micro-service
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development
LOG_LEVEL=info

# --- Infrastructure Ports (Host Side) ---
PORT_POSTGRES_ORDER=5432
PORT_POSTGRES_INVENTORY=5433
PORT_MONGODB_PAYMENT=27017
PORT_REDIS=6379

# --- Service Ports (Host Side Mapping) ---
PORT_IDENTITY_SERVICE=5010
PORT_ORDER_SERVICE=5011
PORT_PAYMENT_SERVICE=5012
PORT_INVENTORY_SERVICE=5013
PORT_CART_SERVICE=5014
PORT_PDF_SERVICE=5015

# --- Internal Ports (Container Side - REST) ---
INTERNAL_PORT_PAYMENT=5012
INTERNAL_PORT_INVENTORY=5013
INTERNAL_PORT_CART=5014
INTERNAL_PORT_PDF=5015

# --- Internal Ports (Container Side - gRPC) ---
INTERNAL_PORT_GRPC_IDENTITY=50010
INTERNAL_PORT_GRPC_ORDER=50011
INTERNAL_PORT_GRPC_PAYMENT=50012
INTERNAL_PORT_GRPC_INVENTORY=50013

# --- Database Credentials ---
DB_USER=
DB_PASSWORD=

# --- Database Names ---
DB_NAME_ORDER=orders_db
DB_NAME_INVENTORY=inventory_db
DB_NAME_PAYMENT=payments_db

# --- MinIO Credentials ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- JWT Secret (IdentityService) ---
JWT_SECRET=

# --- CORS (handled by Kong gateway — comma-separated origins) ---
KONG_CORS_ORIGINS=http://localhost:8080,http://localhost:8100

# --- Service Identity ---
SERVICE_VERSION=1.0.0

# --- Internal Service URLs (Docker network) ---
GRPC_URL_PAYMENT=http://payment-service:50012
GRPC_URL_INVENTORY=http://inventory-service:50013
GRPC_URL_IDENTITY=http://identity-service:50010
HTTP_URL_PDF=http://pdf-service:5015
REDIS_URL=redis://redis:6379/0
ORDER_SERVICE_URL=order-service:50011
S3_ENDPOINT=http://minio:9000

# --- Tuning ---
CIRCUIT_BREAKER_TIMEOUT=3000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOKI_URL=http://loki:3100
