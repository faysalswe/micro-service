# ==============================================================================
# MICROSERVICES CENTRAL CONFIGURATION (Root .env)
# ==============================================================================

# --- Global Settings ---
COMPOSE_PROJECT_NAME=micro-service
PROJECT_NAME=micro-service
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development
LOG_LEVEL=info

# --- Infrastructure Ports (Host Side) ---
PORT_POSTGRES_ORDER=5432
PORT_POSTGRES_INVENTORY=5433
PORT_MONGODB_PAYMENT=27017
PORT_REDIS=6379
PORT_KONG_HTTP=8000
PORT_KONG_ADMIN=8001
PORT_JAEGER_UI=16686
PORT_PROMETHEUS=9090
PORT_GRAFANA=3301

# --- Service Ports (Host Side Mapping) ---
PORT_IDENTITY_SERVICE=5010
PORT_ORDER_SERVICE=5011
PORT_PAYMENT_SERVICE=5012
PORT_INVENTORY_SERVICE=5013

# --- Internal Ports (Container Side - REST) ---
INTERNAL_PORT_IDENTITY=5010
INTERNAL_PORT_ORDER=5011
INTERNAL_PORT_PAYMENT=5012
INTERNAL_PORT_INVENTORY=5013

# --- Internal Ports (Container Side - gRPC) ---
INTERNAL_PORT_GRPC_ORDER=50011
INTERNAL_PORT_GRPC_PAYMENT=50012
INTERNAL_PORT_GRPC_INVENTORY=50013

# --- Database Credentials ---
DB_USER=admin
DB_PASSWORD=password123

# --- Service Discovery (URLs used by services to talk to each other) ---
# Note: Use service names for Docker, localhost for local dev
URL_IDENTITY_SERVICE=http://identity-service:5010
URL_ORDER_SERVICE=http://order-service:5011
URL_PAYMENT_SERVICE=http://payment-service:5012
URL_INVENTORY_SERVICE=http://inventory-service:5013

# --- gRPC Service Discovery ---
URL_ORDER_SERVICE_GRPC=http://order-service:50011
URL_PAYMENT_SERVICE_GRPC=http://payment-service:50012
URL_INVENTORY_SERVICE_GRPC=http://inventory-service:50013

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOKI_URL=http://loki:3100
PROMETHEUS_URL=http://prometheus:9090
