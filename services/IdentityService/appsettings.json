{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=identity.db"
  },
  "Jwt": {
    "Key": "ThisIsAVerySecretKeyForDevelopmentOnly123!",
    "Issuer": "IdentityService",
    "Audience": "MicroserviceApp"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5009"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5010",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://+:50010",
        "Protocols": "Http2"
      }
    }
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "IdentityService",
    "Version": "1.0.0"
  }
}
